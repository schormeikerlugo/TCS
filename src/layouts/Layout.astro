---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'TCS Edmonton | Total Construction Solutions — General Contractor Alberta',
  description = 'TCS Edmonton — Expert general contracting, commercial construction, project management and renovation services across Edmonton, Alberta. Quality builds, on-time delivery, trusted by businesses and homeowners.',
  image = '/images/img1.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="TCS Edmonton, construction Edmonton, general contractor Alberta, commercial construction Edmonton, renovation Edmonton, project management Alberta, building contractor YEG, construction company Edmonton, TCS YEG" />
    <meta name="author" content="TCS Edmonton" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#080c14" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:locale" content="en_CA" />
    <meta property="og:site_name" content="TCS Edmonton" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    <!-- Geo -->
    <meta name="geo.region" content="CA-AB" />
    <meta name="geo.placename" content="Edmonton" />
    <meta name="geo.position" content="53.5461;-113.4937" />
    <meta name="ICBM" content="53.5461, -113.4937" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,600;1,700&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet" />

    <title>{title}</title>

    <!-- JSON-LD Structured Data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "GeneralContractor",
      "name": "TCS Edmonton",
      "alternateName": "Total Construction Solutions",
      "description": description,
      "url": "https://tcsyeg.com",
      "logo": "https://tcsyeg.com/favicon.svg",
      "image": new URL(image, Astro.site),
      "telephone": "+1-780-000-0000",
      "email": "info@tcsyeg.com",
      "areaServed": [
        { "@type": "City", "name": "Edmonton", "containedInPlace": { "@type": "AdministrativeArea", "name": "Alberta" } },
        { "@type": "City", "name": "Sherwood Park" },
        { "@type": "City", "name": "Spruce Grove" },
        { "@type": "City", "name": "St. Albert" },
        { "@type": "City", "name": "Fort Saskatchewan" },
        { "@type": "City", "name": "Leduc" }
      ],
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Edmonton",
        "addressRegion": "AB",
        "addressCountry": "CA"
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "07:00",
        "closes": "18:00"
      },
      "knowsAbout": [
        "General Contracting", "Commercial Construction", "Industrial Construction",
        "Residential Renovation", "Project Management", "Concrete Work",
        "Steel Structures", "Roofing", "Earthwork", "Site Development"
      ]
    })} />
  </head>
  <body class="bg-primary antialiased">

<style is:global>
  .nav-scrolled {
    background: rgba(8, 12, 20, 0.88) !important;
    -webkit-backdrop-filter: blur(20px) !important;
    backdrop-filter: blur(20px) !important;
  }
  .glass {
    background: rgba(37, 99, 235, 0.04);
    -webkit-backdrop-filter: blur(24px);
    backdrop-filter: blur(24px);
    border: 1px solid rgba(37, 99, 235, 0.1);
    transform: translateZ(0);
  }
  .glass-card {
    background: rgba(15, 24, 41, 0.75);
    -webkit-backdrop-filter: blur(24px);
    backdrop-filter: blur(24px);
    border: 1px solid rgba(37, 99, 235, 0.1);
    transform: translateZ(0);
  }
  .glass-heavy {
    background: rgba(15, 24, 41, 0.8);
    -webkit-backdrop-filter: blur(40px);
    backdrop-filter: blur(40px);
    border: 1px solid rgba(37, 99, 235, 0.15);
    transform: translateZ(0);
  }
  .glass-card-fast {
    background: rgba(15, 24, 41, 0.7);
    -webkit-backdrop-filter: blur(24px);
    backdrop-filter: blur(24px);
    border: 1px solid rgba(37, 99, 235, 0.1);
    transform: translateZ(0);
  }
  .glass-bevel {
    background: rgba(15, 24, 41, 0.45);
    -webkit-backdrop-filter: blur(24px);
    backdrop-filter: blur(24px);
    border: 1px solid rgba(37, 99, 235, 0.35);
    transform: translateZ(0);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.12),
      inset 0 -1px 0 rgba(37, 99, 235, 0.15),
      inset 1px 0 0 rgba(255, 255, 255, 0.06),
      inset -1px 0 0 rgba(37, 99, 235, 0.1),
      0 0 40px rgba(37, 99, 235, 0.08);
  }
</style>
    <slot />

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('.reveal').forEach((el) => {
        observer.observe(el);
      });
    </script>
  </body>
</html>

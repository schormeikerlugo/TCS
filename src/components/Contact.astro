<div class="geo-divider"></div>

<section id="contact" class="relative overflow-hidden min-h-[700px]">
  <span class="section-number absolute top-8 right-8 lg:right-16 z-10">08 / 08</span>

  <div class="grid lg:grid-cols-2 min-h-[700px]">

    <!-- Left panel: image + overlay copy -->
    <div class="relative h-[50vw] lg:h-auto overflow-hidden">
      <img
        src="/images/img13.jpg"
        alt="TCS Construction — contact"
        class="absolute inset-0 w-full h-full object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-primary/20 to-primary/70"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-primary/80 via-transparent to-primary/30"></div>

      <!-- Content overlay -->
      <div class="absolute inset-0 flex flex-col justify-end p-8 lg:p-12">
        <p class="text-accent text-[10px] tracking-[0.4em] uppercase font-mono mb-4 flex items-center gap-3">
          <span class="w-5 h-px bg-accent"></span> Get In Touch
        </p>
        <h2 class="heading-statement text-white mb-6" style="font-size: clamp(2rem, 4vw, 4.5rem);">
          <span class="thin">Start your</span><br>
          <span class="serif-accent">project today.</span>
        </h2>
        <p class="text-white/40 text-sm leading-relaxed max-w-xs mb-8">
          Tell us about your project. We'll connect you with the right team within 24 hours.
        </p>

        <!-- Contact details -->
        <div class="space-y-3">
          {[
            { label: 'Email', value: 'info@tcsyeg.com' },
            { label: 'Hours', value: 'Mon – Fri · 7AM – 6PM' },
            { label: 'Location', value: 'Edmonton, Alberta' },
          ].map((item) => (
            <div class="flex items-center gap-3">
              <span class="text-accent/40 text-[9px] tracking-[0.3em] uppercase font-mono w-14 shrink-0">{item.label}</span>
              <span class="w-4 h-px bg-white/10"></span>
              <span class="text-white/50 text-sm">{item.value}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Right panel: form -->
    <div class="relative flex flex-col justify-center px-8 sm:px-12 lg:px-14 xl:px-16 py-16 lg:py-20 bg-surface-dark">
      <div class="grid-overlay opacity-50"></div>
      <div class="absolute inset-0 bg-gradient-to-br from-accent/3 to-transparent pointer-events-none"></div>

      <form
        class="relative z-10 space-y-5 max-w-lg"
        name="contact"
        method="POST"
      >
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="name" class="block text-white/35 text-[10px] tracking-[0.2em] uppercase font-mono mb-2">Name *</label>
            <input type="text" id="name" name="name" required placeholder="Your name"
              class="w-full bg-white/[0.04] border border-white/8 px-4 py-3.5 text-white text-sm placeholder:text-white/20 focus:border-accent/40 focus:bg-white/[0.06] outline-none transition-all" />
          </div>
          <div>
            <label for="email" class="block text-white/35 text-[10px] tracking-[0.2em] uppercase font-mono mb-2">Email *</label>
            <input type="email" id="email" name="email" required placeholder="your@email.com"
              class="w-full bg-white/[0.04] border border-white/8 px-4 py-3.5 text-white text-sm placeholder:text-white/20 focus:border-accent/40 focus:bg-white/[0.06] outline-none transition-all" />
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="phone" class="block text-white/35 text-[10px] tracking-[0.2em] uppercase font-mono mb-2">Phone</label>
            <input type="tel" id="phone" name="phone" placeholder="(780) 000-0000"
              class="w-full bg-white/[0.04] border border-white/8 px-4 py-3.5 text-white text-sm placeholder:text-white/20 focus:border-accent/40 focus:bg-white/[0.06] outline-none transition-all" />
          </div>
          <div>
            <label for="service" class="block text-white/35 text-[10px] tracking-[0.2em] uppercase font-mono mb-2">Service Type</label>
            <select id="service" name="service"
              class="w-full bg-[#0a0f1c] border border-white/8 px-4 py-3.5 text-white/50 text-sm focus:border-accent/40 outline-none transition-all appearance-none cursor-pointer">
              <option value="">Select a service</option>
              <option>General Contracting</option>
              <option>Commercial Construction</option>
              <option>Industrial Build</option>
              <option>Residential Renovation</option>
              <option>Project Management</option>
              <option>Site Development</option>
              <option>Other</option>
            </select>
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="budget" class="block text-white/35 text-[10px] tracking-[0.2em] uppercase font-mono mb-2">Budget Range</label>
            <select id="budget" name="budget"
              class="w-full bg-[#0a0f1c] border border-white/8 px-4 py-3.5 text-white/50 text-sm focus:border-accent/40 outline-none transition-all appearance-none cursor-pointer">
              <option value="">Approximate budget</option>
              <option>Under $50K</option>
              <option>$50K – $250K</option>
              <option>$250K – $1M</option>
              <option>$1M – $5M</option>
              <option>$5M+</option>
            </select>
          </div>
          <div>
            <label for="timeline" class="block text-white/35 text-[10px] tracking-[0.2em] uppercase font-mono mb-2">Start Timeline</label>
            <select id="timeline" name="timeline"
              class="w-full bg-[#0a0f1c] border border-white/8 px-4 py-3.5 text-white/50 text-sm focus:border-accent/40 outline-none transition-all appearance-none cursor-pointer">
              <option value="">When do you need us?</option>
              <option>ASAP</option>
              <option>Within 1 month</option>
              <option>1 – 3 months</option>
              <option>3 – 6 months</option>
              <option>6+ months</option>
            </select>
          </div>
        </div>

        <div>
          <label for="message" class="block text-white/35 text-[10px] tracking-[0.2em] uppercase font-mono mb-2">Project Details *</label>
          <textarea id="message" name="message" rows="4" required placeholder="Describe your project..."
            class="w-full bg-white/[0.04] border border-white/8 px-4 py-3.5 text-white text-sm placeholder:text-white/20 focus:border-accent/40 focus:bg-white/[0.06] outline-none transition-all resize-none"></textarea>
        </div>

        <button type="submit"
          class="group w-full sm:w-auto flex items-center justify-center gap-3 bg-accent hover:bg-accent-hover text-white text-sm px-10 py-4 font-medium tracking-[0.05em] transition-all hover:shadow-xl hover:shadow-accent/20 hover:-translate-y-0.5 active:translate-y-0">
          Send Request
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </button>
      </form>
    </div>
  </div>
</section>

<div class="geo-divider"></div>

<section id="contact" class="relative overflow-hidden min-h-screen">
  <span class="section-number absolute top-8 right-8 lg:right-16 z-20"
    >09 / 09</span
  >

  <!-- Full-width background image -->
  <div class="absolute inset-0">
    <img
      src="/images/img13.webp"
      alt="TCS — Edmonton permit consulting contact"
      class="w-full h-full object-cover"
      loading="lazy"
    />
    <!-- Dark tint overlay -->
    <div class="absolute inset-0 bg-primary/75"></div>
    <!-- Subtle blue atmospheric glow -->
    <div
      class="absolute bottom-0 left-1/4 w-[700px] h-[500px] bg-accent/10 rounded-full blur-[200px] pointer-events-none"
    >
    </div>
  </div>

  <!-- Content -->
  <div class="relative z-10 px-8 sm:px-14 lg:px-20 xl:px-28 py-20 lg:py-28">
    <!-- Header -->
    <div class="mb-16 lg:mb-20">
      <!-- Mobile shape above title -->
      <div class="flex justify-center mb-8 lg:hidden">
        <div class="relative" style="width:60px;height:60px;">
          <div class="shape-pyramid" style="position:absolute;top:0;left:0;">
            <div class="tri"></div><div class="tri"></div><div class="tri">
            </div>
          </div>
        </div>
      </div>

      <!-- Desktop bg shape -->
      <div
        class="shape-cube hidden lg:block"
        style="position:absolute;top:8%;right:6%;opacity:0.3;"
      >
        <div class="face"></div><div class="face"></div><div class="face"></div>
        <div class="face"></div><div class="face"></div><div class="face"></div>
      </div>

      <p
        class="reveal text-accent text-[10px] tracking-[0.4em] uppercase font-mono mb-5 flex items-center justify-center lg:justify-start gap-3"
      >
        <span class="w-5 h-px bg-accent"></span> Get In Touch
      </p>
      <h2
        class="reveal heading-statement text-center lg:text-left"
        style="font-size: clamp(2.5rem, 7vw, 6rem);"
      >
        <span class="thin">Get a</span><br />
        <span class="serif-accent">free quote.</span>
      </h2>
    </div>

    <div class="grid lg:grid-cols-12 gap-6 lg:gap-8 items-start">
      <!-- Left: info cards stacked -->
      <div class="lg:col-span-4 flex flex-col gap-4">
        <!-- Intro text -->
        <p
          class="reveal text-white/45 text-sm leading-relaxed mb-2"
          data-delay="1"
        >
          Tell us about your project and we'll reply within 1 business day with
          a clear scope and quote.
        </p>

        <!-- Bevel glass info cards -->
        {
          [
            {
              icon: "M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z",
              label: "Location",
              value: "Edmonton, Alberta, Canada",
            },
            {
              icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z",
              label: "Working Hours",
              value: "Mon – Fri · 7:00 AM – 6:00 PM",
            },
            {
              icon: "M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
              label: "Email",
              value: "Permits@tcsyeg.com",
            },
            {
              icon: "M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z",
              label: "Phone",
              value: "(780) 885-1687",
            },
          ].map((card, i) => (
            <div
              class="reveal glass-bevel rounded-xl p-5 flex items-center gap-4 group hover:border-accent/60 transition-all duration-300"
              data-delay={String(i + 2)}
            >
              <div class="w-10 h-10 rounded-lg bg-accent/15 border border-accent/20 flex items-center justify-center shrink-0 group-hover:bg-accent/25 transition-colors duration-300">
                <svg
                  class="w-4.5 h-4.5 text-accent"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  style="width:18px;height:18px;"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d={card.icon}
                  />
                </svg>
              </div>
              <div>
                <p class="text-white/35 text-[10px] tracking-[0.2em] uppercase font-mono mb-0.5">
                  {card.label}
                </p>
                <p class="text-white text-sm font-medium">{card.value}</p>
              </div>
            </div>
          ))
        }
      </div>

      <!-- Right: form in a bevel glass card -->
      <div class="lg:col-span-8 reveal" data-delay="2">
        <div class="glass-bevel rounded-2xl p-8 lg:p-10">
          <form class="space-y-5" name="contact" method="POST">
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label
                  for="first-name"
                  class="block text-white/35 text-[10px] tracking-[0.2em] uppercase font-mono mb-2"
                  >First Name *</label
                >
                <input
                  type="text"
                  id="first-name"
                  name="first-name"
                  required
                  placeholder="Your first name"
                  class="w-full bg-white/[0.05] border border-accent/15 px-4 py-3.5 text-white text-sm placeholder:text-white/20 focus:border-accent/50 focus:bg-white/[0.08] outline-none transition-all"
                />
              </div>
              <div>
                <label
                  for="last-name"
                  class="block text-white/35 text-[10px] tracking-[0.2em] uppercase font-mono mb-2"
                  >Last Name *</label
                >
                <input
                  type="text"
                  id="last-name"
                  name="last-name"
                  required
                  placeholder="Your last name"
                  class="w-full bg-white/[0.05] border border-accent/15 px-4 py-3.5 text-white text-sm placeholder:text-white/20 focus:border-accent/50 focus:bg-white/[0.08] outline-none transition-all"
                />
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label
                  for="phone"
                  class="block text-white/35 text-[10px] tracking-[0.2em] uppercase font-mono mb-2"
                  >Phone Number *</label
                >
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  required
                  placeholder="(780) 000-0000"
                  class="w-full bg-white/[0.05] border border-accent/15 px-4 py-3.5 text-white text-sm placeholder:text-white/20 focus:border-accent/50 focus:bg-white/[0.08] outline-none transition-all"
                />
              </div>
              <div>
                <label
                  for="address"
                  class="block text-white/35 text-[10px] tracking-[0.2em] uppercase font-mono mb-2"
                  >Property Address *</label
                >
                <input
                  type="text"
                  id="address"
                  name="address"
                  required
                  placeholder="Street address"
                  class="w-full bg-white/[0.05] border border-accent/15 px-4 py-3.5 text-white text-sm placeholder:text-white/20 focus:border-accent/50 focus:bg-white/[0.08] outline-none transition-all"
                />
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label
                  for="postal-code"
                  class="block text-white/35 text-[10px] tracking-[0.2em] uppercase font-mono mb-2"
                  >Postal Code *</label
                >
                <input
                  type="text"
                  id="postal-code"
                  name="postal-code"
                  required
                  placeholder="T5J 0N3"
                  class="w-full bg-white/[0.05] border border-accent/15 px-4 py-3.5 text-white text-sm placeholder:text-white/20 focus:border-accent/50 focus:bg-white/[0.08] outline-none transition-all"
                />
              </div>
              <div>
                <label
                  for="city"
                  class="block text-white/35 text-[10px] tracking-[0.2em] uppercase font-mono mb-2"
                  >City *</label
                >
                <input
                  type="text"
                  id="city"
                  name="city"
                  required
                  placeholder="Your city"
                  class="w-full bg-white/[0.05] border border-accent/15 px-4 py-3.5 text-white text-sm placeholder:text-white/20 focus:border-accent/50 focus:bg-white/[0.08] outline-none transition-all"
                />
              </div>
            </div>

            <div>
              <label
                for="message"
                class="block text-white/35 text-[10px] tracking-[0.2em] uppercase font-mono mb-2"
                >Project Details *</label
              >
              <textarea
                id="message"
                name="message"
                rows="4"
                required
                placeholder="Describe your project..."
                class="w-full bg-white/[0.05] border border-accent/15 px-4 py-3.5 text-white text-sm placeholder:text-white/20 focus:border-accent/50 focus:bg-white/[0.08] outline-none transition-all resize-none"
              ></textarea>
            </div>

            <button
              type="submit"
              class="group w-full sm:w-auto flex items-center justify-center gap-3 bg-accent hover:bg-accent-hover text-white text-sm px-10 py-4 font-medium tracking-[0.05em] transition-all hover:shadow-xl hover:shadow-accent/25 hover:-translate-y-0.5 active:translate-y-0"
            >
              Send Request
              <svg
                class="w-4 h-4 transition-transform group-hover:translate-x-0.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
              >
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

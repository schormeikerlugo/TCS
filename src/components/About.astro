<section id="about" class="relative overflow-hidden">
  <!-- Marquee ribbon -->
  <div class="py-5 border-b border-accent/8 overflow-hidden">
    <div class="marquee-track flex whitespace-nowrap">
      {
        [...Array(2)].map(() => (
          <span class="flex items-center gap-8 mr-8 text-white/12 text-[11px] tracking-[0.35em] uppercase font-mono">
            <>
              <span>General Contracting</span>
              <span class="text-accent">&#9670;</span>
            </>
            <>
              <span>Commercial Construction</span>
              <span class="text-accent">&#9670;</span>
            </>
            <>
              <span>Industrial Builds</span>
              <span class="text-accent">&#9670;</span>
            </>
            <>
              <span>Project Management</span>
              <span class="text-accent">&#9670;</span>
            </>
            <>
              <span>Site Development</span>
              <span class="text-accent">&#9670;</span>
            </>
            <>
              <span>Residential Renovation</span>
              <span class="text-accent">&#9670;</span>
            </>
            <>
              <span>Structural Work</span>
              <span class="text-accent">&#9670;</span>
            </>
            <>
              <span>Interior Fit-outs</span>
              <span class="text-accent">&#9670;</span>
            </>
          </span>
        ))
      }
    </div>
  </div>

  <!-- Magazine layout: text left, image right -->
  <div class="grid lg:grid-cols-2 min-h-[80vh]">
    <!-- Left: content -->
    <div
      class="relative flex flex-col justify-center px-8 sm:px-14 lg:px-20 xl:px-28 py-16 lg:py-20 bg-primary order-2 lg:order-1"
    >
      <div class="grid-overlay"></div>
      <div class="relative z-10 max-w-xl">
        <p
          class="reveal text-accent text-[10px] tracking-[0.4em] uppercase font-mono mb-8 flex items-center gap-3"
        >
          <span class="w-5 h-px bg-accent"></span> Who We Are
        </p>

        <h2
          class="reveal heading-statement mb-8"
          style="font-size: clamp(2.2rem, 5vw, 5rem); line-height: 0.92;"
        >
          <span class="thin">Building</span><br />
          Alberta's<br />
          <span class="serif-accent">future.</span>
        </h2>

        <p
          class="reveal text-white/45 text-base leading-relaxed mb-6"
          data-delay="1"
        >
          TCS has been Edmonton's go-to general contractor since 2010. We
          specialize in commercial construction, industrial projects, and
          full-scale renovations — bringing unmatched expertise, precision, and
          accountability to every single build.
        </p>

        <p
          class="reveal text-white/30 text-sm leading-relaxed mb-10"
          data-delay="2"
        >
          From concept to completion, one team handles it all. No subcontractor
          maze, no communication gaps — just one accountable partner with the
          experience to deliver.
        </p>

        <!-- Three pillars -->
        <div class="reveal space-y-4" data-delay="3">
          {
            [
              {
                label: "Licensed & Bonded",
                desc: "Fully licensed across Alberta. Every build protected.",
              },
              {
                label: "On-Time Delivery",
                desc: "Milestone-driven planning. Your schedule respected.",
              },
              {
                label: "Full-Scope Coverage",
                desc: "Site prep to final handover — one team, zero gaps.",
              },
            ].map((item) => (
              <div class="flex items-start gap-4 py-4 border-b border-white/5 last:border-0 group">
                <span class="w-1.5 h-1.5 rounded-full bg-accent mt-1.5 shrink-0 group-hover:scale-150 transition-transform duration-300" />
                <div>
                  <p class="text-white text-sm font-medium mb-0.5">
                    {item.label}
                  </p>
                  <p class="text-white/35 text-sm">{item.desc}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Right: full-bleed image -->
    <div
      class="relative h-[55vw] lg:h-auto overflow-hidden order-1 lg:order-2 rounded-bl-3xl"
    >
      <img
        src="/images/img1.jpg"
        alt="TCS Construction — Edmonton build site"
        class="absolute inset-0 w-full h-full object-cover"
        loading="lazy"
      />
      <div
        class="absolute inset-0 bg-gradient-to-l from-transparent to-primary/30"
      >
      </div>
      <div
        class="absolute inset-0 bg-gradient-to-t from-primary/70 via-transparent to-transparent lg:hidden"
      >
      </div>

      <!-- Section number -->
      <span class="section-number absolute top-8 right-8">02 / 08</span>

      <!-- Bottom label — glass bevel card with float animation -->
      <div
        id="about-badge"
        class="absolute bottom-8 right-8 hidden lg:block glass-bevel rounded-xl px-5 py-3.5"
      >
        <p
          class="text-white/70 text-[11px] font-mono tracking-[0.3em] uppercase"
        >
          Edmonton, Alberta
        </p>
        <p class="text-accent/50 text-[10px] font-mono mt-1 tracking-wider">
          N 53°32' · W 113°29'
        </p>
      </div>

      <script>
        const badge = document.getElementById("about-badge");
        if (badge) {
          let t = 0;
          const animate = () => {
            t += 0.005;
            const ty = Math.sin(t) * 8;
            const tx = Math.cos(t * 0.6) * 3;
            badge.style.transform = `translate(${tx}px, ${ty}px)`;
            requestAnimationFrame(animate);
          };
          animate();
        }
      </script>
    </div>
  </div>
</section>

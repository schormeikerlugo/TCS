<section id="hero" class="relative h-screen min-h-[600px] max-h-[1000px] flex flex-col justify-end overflow-hidden noise">

  <!-- Background video -->
  <video autoplay muted loop playsinline preload="auto"
    class="absolute inset-0 w-full h-full object-cover scale-[1.02]">
    <source src="/hero.mov" type="video/mp4" />
    <source src="/hero.mov" type="video/quicktime" />
  </video>

  <!-- Layered overlays -->
  <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/55 to-primary/15"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-primary/75 via-transparent to-transparent"></div>

  <!-- Atmospheric glow -->
  <div class="absolute top-1/3 right-1/4 w-[500px] h-[300px] bg-accent/6 rounded-full blur-[120px] pointer-events-none"></div>


  <!-- Section counter -->
  <span class="section-number absolute top-24 right-8 lg:right-16 z-10">01 / 08</span>

  <!-- ─── Main content ─── -->
  <div class="relative z-10 w-full px-8 sm:px-14 lg:px-20 xl:px-28 pb-14 lg:pb-20">

    <!-- Eyebrow -->
    <p class="reveal mb-6 text-white/35 text-[10px] tracking-[0.4em] uppercase font-mono flex items-center gap-3">
      <span class="w-6 h-px bg-accent/60 inline-block"></span>
      Edmonton, Alberta &middot; Est. 2010
    </p>

    <!-- Statement headline -->
    <h1 class="heading-statement mb-8 lg:mb-10">
      <span class="block reveal" style="font-size: clamp(2.8rem, 8vw, 7.5rem);">
        <span class="thin">Built</span> strong.
      </span>
      <span class="block reveal" data-delay="1" style="font-size: clamp(2.8rem, 8vw, 7.5rem);">
        Delivered <span class="serif-accent">on time.</span>
      </span>
      <span class="block reveal" data-delay="2" style="font-size: clamp(2.8rem, 8vw, 7.5rem);">
        <span class="outline-text">Every</span> project.
      </span>
    </h1>

    <!-- Subtitle -->
    <p class="reveal text-white/45 text-sm leading-relaxed max-w-sm mb-7" data-delay="3">
      Edmonton's trusted general contractor — commercial builds,
      industrial projects, and full-scale renovations handled by
      one expert team from groundbreaking to final inspection.
    </p>

    <!-- CTA buttons — directly below subtitle -->
    <div class="reveal flex flex-row items-center gap-4 mb-12 lg:mb-16" data-delay="4">
      <a href="#contact"
        class="group inline-flex items-center gap-2.5 bg-accent hover:bg-accent-hover text-white text-sm px-7 py-3.5 font-medium tracking-[0.04em] transition-all hover:shadow-xl hover:shadow-accent/20 hover:-translate-y-0.5">
        Start a Project
        <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
      <a href="#about"
        class="text-white/40 hover:text-white text-[11px] tracking-[0.25em] uppercase font-mono transition-colors">
        Learn more
      </a>
    </div>

    <!-- Bottom row: geo only -->
    <div class="reveal hidden lg:flex flex-col gap-0.5" data-delay="5">
      <p class="text-white/20 text-[10px] font-mono tracking-wider">N 53°32' 46" &nbsp;·&nbsp; W 113°29' 38" &nbsp;·&nbsp; Alberta, CA</p>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 hidden lg:flex flex-col items-center gap-2">
    <div class="w-px h-10 bg-gradient-to-b from-transparent via-white/20 to-transparent animate-pulse"></div>
    <span class="text-white/25 text-[9px] tracking-[0.35em] uppercase font-mono">Scroll</span>
  </div>
</section>

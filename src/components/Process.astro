---
const steps = [
  {
    num: "01",
    title: "Free Consultation",
    desc: "15 minutes, scoped over phone or Zoom. Tell us what you're building — we'll tell you exactly what permits and approvals you need.",
    icon: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z",
  },
  {
    num: "02",
    title: "Scope & Quote",
    desc: "Clear breakdown of what TCS handles, timelines, and fees. You know exactly what you're paying for before we start.",
    icon: "M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2",
  },
  {
    num: "03",
    title: "Prepare & Submit",
    desc: "We prepare the drawings, documents, and full application package, then submit to the Authority Having Jurisdiction.",
    icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
  },
  {
    num: "04",
    title: "Manage to Approval",
    desc: "We respond to comments, coordinate inspections, and deliver your approved permit. Most residential files close in 3–6 weeks.",
    icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z",
  },
];
---

<div class="geo-divider"></div>

<section id="process" class="py-20 lg:py-28 relative overflow-hidden">
  <div class="grid-overlay"></div>
  <!-- Desktop bg shape -->
  <div class="shape-pyramid hidden lg:block" style="top: 12%; left: 5%;">
    <div class="tri"></div><div class="tri"></div><div class="tri"></div>
  </div>

  <span class="section-number absolute top-8 right-8 lg:right-16 z-10">06 / 09</span>

  <div class="px-8 sm:px-14 lg:px-20 xl:px-28 relative z-10">

    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 mb-16 lg:mb-20">
      <div>
        <!-- Mobile shape above title -->
        <div class="flex justify-center mb-8 lg:hidden">
          <div class="relative" style="width:60px;height:60px;">
            <div class="shape-pyramid" style="position:absolute;top:0;left:0;">
              <div class="tri"></div><div class="tri"></div><div class="tri"></div>
            </div>
          </div>
        </div>

        <p class="reveal text-accent text-[10px] tracking-[0.4em] uppercase font-mono mb-6 flex items-center justify-center lg:justify-start gap-3">
          <span class="w-5 h-px bg-accent"></span> How We Work
        </p>
        <h2 class="reveal heading-statement text-center lg:text-left" style="font-size: clamp(2.5rem, 7vw, 6rem);">
          <span class="thin">A process</span><br>
          built for<br>
          <span class="serif-accent">results.</span>
        </h2>
      </div>
      <div class="flex items-end">
        <p class="reveal text-white/35 text-sm leading-relaxed max-w-sm text-center lg:text-left mx-auto lg:mx-0" data-delay="1">
          Four phases. One team. No guesswork — a structured approach that's delivered 500+ approved permits across Edmonton.
        </p>
      </div>
    </div>

    <!-- Horizontal timeline (desktop) -->
    <div class="hidden lg:block relative">
      <!-- Connecting line -->
      <div class="absolute top-10 left-0 right-0 h-px">
        <div class="h-full bg-gradient-to-r from-transparent via-accent/20 to-transparent"></div>
      </div>

      <div class="grid grid-cols-4 gap-6 relative z-10">
        {steps.map((step, i) => (
          <div class="reveal flex flex-col gap-6 group" data-delay={String(i + 1)}>
            <!-- Node -->
            <div class="flex items-center justify-start">
              <div class="w-20 h-20 rounded-full border border-accent/20 flex items-center justify-center bg-primary group-hover:border-accent/50 group-hover:bg-accent/5 transition-all duration-500 relative">
                <svg class="w-8 h-8 text-accent/40 group-hover:text-accent transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d={step.icon} />
                </svg>
                <!-- Number badge -->
                <span class="absolute -top-2 -right-2 w-6 h-6 rounded-full bg-accent/20 border border-accent/30 flex items-center justify-center text-[9px] font-mono text-accent">{step.num}</span>
              </div>
            </div>

            <!-- Content -->
            <div>
              <h3 class="text-white font-medium text-lg mb-3 group-hover:text-accent transition-colors duration-200">{step.title}</h3>
              <p class="text-white/35 text-sm leading-relaxed">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Vertical list (mobile) -->
    <div class="lg:hidden space-y-0">
      {steps.map((step, i) => (
        <div class="reveal flex gap-6 py-8 border-b border-white/6 last:border-0 group" data-delay={String(i + 1)}>
          <!-- Left: step number + connector -->
          <div class="flex flex-col items-center shrink-0">
            <div class="w-10 h-10 rounded-full border border-accent/25 flex items-center justify-center bg-accent/5">
              <span class="text-accent text-[11px] font-mono">{step.num}</span>
            </div>
            {i < steps.length - 1 && (
              <div class="w-px flex-1 mt-3 bg-gradient-to-b from-accent/20 to-transparent"></div>
            )}
          </div>
          <!-- Right: content -->
          <div class="pb-2">
            <h3 class="text-white font-medium text-lg mb-2 group-hover:text-accent transition-colors duration-200">{step.title}</h3>
            <p class="text-white/35 text-sm leading-relaxed">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

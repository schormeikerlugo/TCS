---
const projects = [
  { name: 'Meridian Office Complex', cat: 'Commercial', sub: '42,000 sq ft · Downtown Edmonton', img: '/images/img2.webp', size: 'tall' },
  { name: 'Northfield Industrial Park', cat: 'Industrial', sub: 'Multi-unit warehouse development', img: '/images/img6.webp', size: 'wide' },
  { name: 'Riverside Medical Centre', cat: 'Healthcare', sub: 'Full-service clinic fit-out', img: '/images/img7.webp', size: 'square' },
  { name: 'Spruce Grove Retail Hub', cat: 'Retail', sub: '18-unit mixed-use strip mall', img: '/images/img8.webp', size: 'square' },
  { name: 'Highland Luxury Renovation', cat: 'Residential', sub: 'Full-home, 5,200 sq ft', img: '/images/img9.webp', size: 'wide' },
  { name: 'Alberta Steel Fabrication Plant', cat: 'Industrial', sub: '80,000 sq ft pre-engineered', img: '/images/img10.webp', size: 'tall' },
];
---

<div class="geo-divider"></div>

<section id="projects" class="py-20 lg:py-28 relative overflow-hidden">
  <div class="grid-overlay"></div>
  <!-- Desktop bg shape -->
  <div class="shape-cube hidden lg:block" style="top: 6%; right: 9%;">
    <div class="face"></div><div class="face"></div><div class="face"></div>
    <div class="face"></div><div class="face"></div><div class="face"></div>
  </div>

  <span class="section-number absolute top-8 right-8 lg:right-16 z-10">04 / 08</span>
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-accent/4 rounded-full blur-[200px] pointer-events-none"></div>

  <div class="px-8 sm:px-14 lg:px-20 xl:px-28 relative z-10">

    <!-- Header -->
    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-6 mb-14">
      <div>
        <!-- Mobile shape above title -->
        <div class="flex justify-center mb-8 lg:hidden">
          <div class="relative" style="width:60px;height:60px;">
            <div class="shape-cube" style="position:absolute;top:0;left:0;opacity:0.5;">
              <div class="face"></div><div class="face"></div><div class="face"></div>
              <div class="face"></div><div class="face"></div><div class="face"></div>
            </div>
          </div>
        </div>

        <p class="reveal text-accent text-[10px] tracking-[0.4em] uppercase font-mono mb-6 flex items-center justify-center lg:justify-start gap-3">
          <span class="w-5 h-px bg-accent"></span> Our Work
        </p>
        <h2 class="reveal heading-statement text-center lg:text-left" style="font-size: clamp(2.5rem, 7vw, 6rem);">
          <span class="thin">Projects</span> that<br>
          <span class="serif-accent">define us.</span>
        </h2>
      </div>
      <p class="reveal text-white/35 text-sm max-w-xs leading-relaxed text-center lg:text-left mx-auto lg:mx-0" data-delay="1">
        A selection of completed work spanning commercial, industrial, and residential construction across Alberta.
      </p>
    </div>

    <!-- Bento grid — taller rows for better image visibility -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 auto-rows-[280px] lg:auto-rows-[300px] gap-4">

      <!-- Item 0 — tall (spans 2 rows) desktop only -->
      <div class="reveal scale-up img-reveal rounded-xl overflow-hidden relative group sm:row-span-2" data-delay="1">
        <img src={projects[0].img} alt={projects[0].name} class="w-full h-full object-cover" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-primary/70 via-primary/10 to-transparent"></div>
        <div class="absolute bottom-5 left-5 right-5">
          <div class="glass-bevel rounded-xl px-4 py-3 translate-y-1 group-hover:translate-y-0 transition-transform duration-300">
            <span class="text-accent text-[9px] tracking-[0.3em] uppercase font-mono">{projects[0].cat}</span>
            <h3 class="text-white text-sm font-medium mt-0.5 leading-tight">{projects[0].name}</h3>
            <p class="text-white/40 text-xs mt-0.5">{projects[0].sub}</p>
          </div>
        </div>
      </div>

      <!-- Item 1 — wide (spans 2 cols on lg) -->
      <div class="reveal scale-up img-reveal rounded-xl overflow-hidden relative group lg:col-span-2" data-delay="2">
        <img src={projects[1].img} alt={projects[1].name} class="w-full h-full object-cover" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-primary/70 via-primary/10 to-transparent"></div>
        <div class="absolute bottom-5 left-5 right-5">
          <div class="glass-bevel rounded-xl px-4 py-3 translate-y-1 group-hover:translate-y-0 transition-transform duration-300">
            <span class="text-accent text-[9px] tracking-[0.3em] uppercase font-mono">{projects[1].cat}</span>
            <h3 class="text-white text-sm font-medium mt-0.5">{projects[1].name}</h3>
            <p class="text-white/40 text-xs mt-0.5">{projects[1].sub}</p>
          </div>
        </div>
      </div>

      <!-- Items 2 & 3 — standard squares -->
      {projects.slice(2, 4).map((project, i) => (
        <div class="reveal scale-up img-reveal rounded-xl overflow-hidden relative group" data-delay={String(i + 3)}>
          <img src={project.img} alt={project.name} class="w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-primary/70 via-primary/10 to-transparent"></div>
          <div class="absolute bottom-5 left-5 right-5">
            <div class="glass-bevel rounded-xl px-4 py-3 translate-y-1 group-hover:translate-y-0 transition-transform duration-300">
              <span class="text-accent text-[9px] tracking-[0.3em] uppercase font-mono">{project.cat}</span>
              <h3 class="text-white text-sm font-medium mt-0.5 leading-tight">{project.name}</h3>
              <p class="text-white/40 text-xs mt-0.5">{project.sub}</p>
            </div>
          </div>
        </div>
      ))}

      <!-- Item 4 — wide bottom (spans 2 cols on lg) -->
      <div class="reveal scale-up img-reveal rounded-xl overflow-hidden relative group lg:col-span-2" data-delay="5">
        <img src={projects[4].img} alt={projects[4].name} class="w-full h-full object-cover" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-primary/70 via-primary/10 to-transparent"></div>
        <div class="absolute bottom-5 left-5 right-5">
          <div class="glass-bevel rounded-xl px-4 py-3 translate-y-1 group-hover:translate-y-0 transition-transform duration-300">
            <span class="text-accent text-[9px] tracking-[0.3em] uppercase font-mono">{projects[4].cat}</span>
            <h3 class="text-white text-sm font-medium mt-0.5">{projects[4].name}</h3>
            <p class="text-white/40 text-xs mt-0.5">{projects[4].sub}</p>
          </div>
        </div>
      </div>

      <!-- Item 5 — standard -->
      <div class="reveal scale-up img-reveal rounded-xl overflow-hidden relative group" data-delay="6">
        <img src={projects[5].img} alt={projects[5].name} class="w-full h-full object-cover" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-primary/70 via-primary/10 to-transparent"></div>
        <div class="absolute bottom-5 left-5 right-5">
          <div class="glass-bevel rounded-xl px-4 py-3 translate-y-1 group-hover:translate-y-0 transition-transform duration-300">
            <span class="text-accent text-[9px] tracking-[0.3em] uppercase font-mono">{projects[5].cat}</span>
            <h3 class="text-white text-sm font-medium mt-0.5 leading-tight">{projects[5].name}</h3>
            <p class="text-white/40 text-xs mt-0.5">{projects[5].sub}</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

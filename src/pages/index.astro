---
import Layout from '../layouts/Layout.astro';
---
<Layout>

<!-- ============ NAVBAR ============ -->
<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 hero-enter" data-hero-delay="1">
  <div class="max-w-[1400px] mx-auto px-6 sm:px-10 lg:px-16 flex items-center justify-between h-20">
    <a href="#" class="flex items-center gap-3">
      <span class="heading-sans text-lg tracking-[0.2em]">TCS</span>
    </a>
    <div class="hidden lg:flex items-center gap-10">
      <a href="#services" class="nav-link text-[11px] tracking-[0.15em] uppercase text-muted hover:text-text transition-colors">Services</a>
      <a href="#who-we-help" class="nav-link text-[11px] tracking-[0.15em] uppercase text-muted hover:text-text transition-colors">Who We Help</a>
      <a href="#process" class="nav-link text-[11px] tracking-[0.15em] uppercase text-muted hover:text-text transition-colors">Process</a>
      <a href="#about" class="nav-link text-[11px] tracking-[0.15em] uppercase text-muted hover:text-text transition-colors">About</a>
      <a href="#faq" class="nav-link text-[11px] tracking-[0.15em] uppercase text-muted hover:text-text transition-colors">FAQ</a>
      <a href="#contact" class="btn-dark text-[11px] py-3 px-6">Book a Free Call</a>
    </div>
    <button id="menu-btn" class="lg:hidden flex flex-col gap-1.5 p-2" aria-label="Toggle menu">
      <span class="w-5 h-px bg-text"></span>
      <span class="w-5 h-px bg-text"></span>
    </button>
  </div>
  <div id="mobile-menu" class="hidden fixed inset-0 top-0 bg-white/95 backdrop-blur-xl z-40 lg:hidden">
    <div class="flex flex-col items-center justify-center h-full gap-8">
      <a href="#services" class="text-lg tracking-[0.1em] uppercase">Services</a>
      <a href="#who-we-help" class="text-lg tracking-[0.1em] uppercase">Who We Help</a>
      <a href="#process" class="text-lg tracking-[0.1em] uppercase">Process</a>
      <a href="#about" class="text-lg tracking-[0.1em] uppercase">About</a>
      <a href="#faq" class="text-lg tracking-[0.1em] uppercase">FAQ</a>
      <a href="#contact" class="btn-dark mt-4">Book a Free Call</a>
    </div>
  </div>
</nav>


<!-- ============ HERO (VIDEO) ============ -->
<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Video background -->
  <div class="absolute inset-0">
    <video autoplay muted loop playsinline preload="auto" class="w-full h-full object-cover">
      <source src="/videos/hero-bg.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-black/50"></div>
  </div>

  <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-10 lg:px-16 text-center text-white py-32">
    <p class="label-mono mb-8 hero-enter text-white/50" data-hero-delay="2">Permit & Planning Consultants</p>

    <h1 class="heading-display text-[clamp(2.5rem,7vw,5rem)] mb-8 max-w-4xl mx-auto hero-enter" data-hero-delay="3">
      Edmonton's Permit, Planning &amp; Approvals Team
    </h1>

    <p class="text-sm text-white/50 leading-relaxed max-w-lg mx-auto mb-10 hero-enter" data-hero-delay="4">
      From deck permits to rezoning, SDAB appeals, and commercial kitchen fire suppression — we handle the paperwork so you can build.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center hero-enter" data-hero-delay="5">
      <a href="#contact" class="inline-flex items-center justify-center gap-2 bg-white text-text px-9 py-4 rounded-sm text-[12px] tracking-[0.1em] uppercase hover:bg-white/90 transition-all duration-300">Book a Free Call</a>
      <a href="#services" class="inline-flex items-center justify-center gap-2 border border-white/25 text-white px-9 py-4 rounded-sm text-[12px] tracking-[0.1em] uppercase hover:bg-white hover:text-text transition-all duration-300">Learn More</a>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 hero-enter" data-hero-delay="7">
      <span class="text-[9px] font-mono tracking-[0.3em] uppercase text-white/30">Scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-white/30 to-transparent"></div>
    </div>
  </div>
</section>


<!-- ============ INTRO SECTION (former hero) ============ -->
<section class="relative py-20 lg:py-28 overflow-hidden">
  <div class="absolute inset-0 grid-pattern"></div>

  <!-- 3D: Cube -->
  <div class="hidden lg:block absolute top-28 right-16" style="perspective: 1200px;">
    <div class="geo-cube w-[96px] h-[96px] relative" style="transform-style: preserve-3d; animation-delay: -3s;">
      <div class="face" style="transform: translateZ(48px);"></div>
      <div class="face" style="transform: translateZ(-48px);"></div>
      <div class="face" style="transform: rotateY(90deg) translateZ(48px);"></div>
      <div class="face" style="transform: rotateY(90deg) translateZ(-48px);"></div>
      <div class="face" style="transform: rotateX(90deg) translateZ(48px);"></div>
      <div class="face" style="transform: rotateX(90deg) translateZ(-48px);"></div>
    </div>
  </div>
  <div class="hidden lg:block absolute bottom-36 left-14">
    <div class="geo-ring w-[72px] h-[72px] relative" style="animation-delay: -5s;"></div>
  </div>

  <div class="max-w-[1400px] mx-auto px-6 sm:px-10 lg:px-16">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
      <!-- Left stats (counters) -->
      <div class="hidden lg:flex lg:col-span-2 flex-col gap-12">
        <div class="reveal">
          <div class="stat-number" data-count="500" data-suffix="+">0</div>
          <div class="w-8 h-px bg-border my-3"></div>
          <p class="text-[11px] text-muted leading-relaxed">Permits approved with full<br/>client satisfaction</p>
        </div>
        <div class="reveal" data-delay="1">
          <div class="stat-number" data-count="15" data-suffix="+">0</div>
          <div class="w-8 h-px bg-border my-3"></div>
          <p class="text-[11px] text-muted leading-relaxed">Years serving Edmonton<br/>and surrounding areas</p>
        </div>
      </div>

      <!-- Center content -->
      <div class="lg:col-span-5 flex flex-col items-center lg:items-start text-center lg:text-left">
        <p class="label-mono mb-8 reveal">Permit & Planning Consultants</p>

        <h2 class="heading-display text-[clamp(2rem,5vw,3.5rem)] mb-8 max-w-lg reveal">
          Edmonton's Permit, Planning &amp; Approvals Team
        </h2>

        <p class="text-sm text-muted leading-relaxed max-w-md mb-10 reveal" data-delay="1">
          With years of expertise in the industry, our dedicated team of permit and planning professionals is here to guide you through every step of the process.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto reveal" data-delay="2">
          <a href="#contact" class="btn-dark justify-center">Book a Free Call</a>
          <a href="#services" class="btn-outline justify-center">Learn More</a>
        </div>

        <!-- Mobile stats (counters) -->
        <div class="flex justify-center gap-10 mt-12 lg:hidden reveal" data-delay="3">
          <div class="text-center"><div class="text-3xl font-extralight" data-count="500" data-suffix="+">0</div><p class="text-[10px] text-muted mt-1">Permits Approved</p></div>
          <div class="text-center"><div class="text-3xl font-extralight" data-count="15" data-suffix="+">0</div><p class="text-[10px] text-muted mt-1">Years Experience</p></div>
          <div class="text-center"><div class="text-3xl font-extralight" data-count="20" data-suffix="+">0</div><p class="text-[10px] text-muted mt-1">Municipalities</p></div>
        </div>
      </div>

      <!-- Right image — 3D tilt -->
      <div class="lg:col-span-5 relative reveal scale-up" style="perspective: 1200px;">
        <div id="hero-tilt" class="relative rounded-sm overflow-hidden aspect-[4/5] transition-transform duration-300 will-change-transform" style="transform-style: preserve-3d;">
          <img src="/images/Rectangle 2.webp" alt="Modern architecture in Edmonton" class="w-full h-full object-cover" loading="lazy" />
          <div id="hero-shine" class="absolute inset-0 pointer-events-none opacity-0 transition-opacity duration-300" style="background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.15) 45%, rgba(255,255,255,0.05) 50%, transparent 55%);"></div>
        </div>
        <!-- Floating badge -->
        <div class="absolute -bottom-4 -left-4 lg:-left-8 bg-white border border-border p-4 rounded-sm shadow-lg reveal" data-delay="2" style="transform: translateZ(40px);">
          <div class="flex items-center gap-3">
            <div class="text-2xl font-extralight">4.9</div>
            <div class="text-amber-500 text-xs">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          </div>
          <p class="text-[10px] text-muted mt-1">789+ Reviews</p>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ============ STATEMENT ============ -->
<section class="py-20 lg:py-32 relative overflow-hidden">
  <!-- 3D: Diamond -->
  <div class="hidden lg:block absolute bottom-20 right-20">
    <div class="geo-diamond w-[64px] h-[64px]" style="animation-delay: -3s;"></div>
  </div>
  <div class="max-w-[1400px] mx-auto px-6 sm:px-10 lg:px-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-end text-center lg:text-left">
      <h2 class="heading-display text-[clamp(1.8rem,4.5vw,3.5rem)] reveal">
        Permits &amp; Planning On Peak Of Excellence
      </h2>
      <div class="reveal flex flex-col items-center lg:items-start" data-delay="1">
        <p class="text-sm text-muted leading-relaxed max-w-md">
          With years of experience in the industry, our dedicated team of permit and planning professionals is here to guide you through every step of the process.
        </p>
        <a href="#services" class="btn-outline mt-6">Learn More</a>
      </div>
    </div>

    <!-- Large image -->
    <div class="mt-16 relative rounded-sm overflow-hidden aspect-[21/9] reveal scale-up">
      <img src="/images/AdobeStock_1439370426.webp" alt="Edmonton construction at sunset" class="w-full h-full object-cover" loading="lazy" />
      <!-- Play button overlay -->
      <div class="absolute bottom-6 left-6 flex items-center gap-3">
        <div class="w-12 h-12 rounded-full border border-white/30 flex items-center justify-center backdrop-blur-sm bg-white/10 cursor-pointer hover:bg-white/20 transition-all">
          <svg class="w-4 h-4 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
        </div>
        <span class="text-white text-[10px] tracking-[0.2em] uppercase">Watch Our Process</span>
      </div>
    </div>
  </div>
</section>


<!-- ============ WHO WE HELP ============ -->
<section id="who-we-help" class="py-20 lg:py-28 bg-surface relative overflow-hidden">
  <div class="absolute inset-0 dot-pattern"></div>
  <!-- 3D: Large ring -->
  <div class="hidden lg:block absolute top-12 -right-6">
    <div class="geo-ring w-[112px] h-[112px] relative" style="animation-delay: -2s;"></div>
  </div>
  <div class="max-w-[1400px] mx-auto px-6 sm:px-10 lg:px-16">
    <div class="section-header mb-16">
      <p class="label-mono mb-6 reveal">Who We Help</p>
      <h2 class="heading-display text-[clamp(2rem,5vw,3.5rem)] max-w-2xl reveal">
        Built for every project scale
      </h2>
    </div>

    <!-- Row 1: Homeowners (image left, text right) -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
      <a href="#services" class="group relative rounded-sm overflow-hidden aspect-[16/10] reveal scale-up block">
        <img src="/images/0_1.webp" alt="Residential home blueprints and planning" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent"></div>
        <div class="absolute bottom-6 left-6 right-6">
          <div class="text-[10px] tracking-[0.2em] uppercase text-white/50 mb-2">01</div>
          <h3 class="text-xl text-white font-normal mb-2">Homeowners</h3>
          <p class="text-sm text-white/60 leading-relaxed">Decks, garages, basements, suites, renovations — we handle the full permit process.</p>
        </div>
        <div class="absolute top-5 right-5 w-8 h-8 rounded-full border border-white/20 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </div>
      </a>

      <a href="#services" class="group relative rounded-sm overflow-hidden aspect-[16/10] reveal scale-up block" data-delay="1">
        <img src="/images/0_0 (1).webp" alt="Commercial building with blueprints" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent"></div>
        <div class="absolute bottom-6 left-6 right-6">
          <div class="text-[10px] tracking-[0.2em] uppercase text-white/50 mb-2">02</div>
          <h3 class="text-xl text-white font-normal mb-2">Restaurants &amp; Businesses</h3>
          <p class="text-sm text-white/60 leading-relaxed">Kitchen hoods, fire suppression, change-of-use, and occupancy so you can open on time.</p>
        </div>
        <div class="absolute top-5 right-5 w-8 h-8 rounded-full border border-white/20 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </div>
      </a>
    </div>

    <!-- Row 2: Developers (wide) + Municipalities (narrow with text card) -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <a href="#services" class="group relative rounded-sm overflow-hidden aspect-[16/10] lg:col-span-2 reveal scale-up block" data-delay="2">
        <img src="/images/0_1 (1).webp" alt="Multi-family development architectural render" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent"></div>
        <div class="absolute bottom-6 left-6 right-6">
          <div class="text-[10px] tracking-[0.2em] uppercase text-white/50 mb-2">03</div>
          <h3 class="text-xl text-white font-normal mb-2">Developers</h3>
          <p class="text-sm text-white/60 leading-relaxed max-w-md">Rezoning, subdivision, SDAB appeals, and full-cycle approvals for residential and commercial developments.</p>
        </div>
        <div class="absolute top-5 right-5 w-8 h-8 rounded-full border border-white/20 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </div>
      </a>

      <a href="#services" class="group relative rounded-sm overflow-hidden aspect-[16/10] lg:aspect-auto reveal scale-up block" data-delay="3">
        <img src="/images/0_2 (1).webp" alt="Municipal planning and community development" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent"></div>
        <div class="absolute bottom-6 left-6 right-6">
          <div class="text-[10px] tracking-[0.2em] uppercase text-white/50 mb-2">04</div>
          <h3 class="text-xl text-white font-normal mb-2">Municipalities &amp; First Nations</h3>
          <p class="text-sm text-white/60 leading-relaxed">Planning capacity, stakeholder engagement, and community-driven policy.</p>
        </div>
        <div class="absolute top-5 right-5 w-8 h-8 rounded-full border border-white/20 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </div>
      </a>
    </div>
  </div>
</section>


<!-- ============ SERVICES ============ -->
<section id="services" class="py-20 lg:py-28 relative overflow-hidden">
  <div class="absolute inset-0 grid-pattern"></div>
  <!-- 3D: Diamond -->
  <div class="hidden lg:block absolute bottom-20 -left-4">
    <div class="geo-diamond w-[88px] h-[88px]" style="animation-delay: -6s;"></div>
  </div>

  <div class="max-w-[1400px] mx-auto px-6 sm:px-10 lg:px-16">
    <div class="section-header text-center mb-16">
      <p class="label-mono mb-6 reveal">Our Services</p>
      <h2 class="heading-display text-[clamp(2rem,5vw,3.5rem)] mb-6 reveal">Full service catalogue</h2>
      <p class="text-sm text-muted leading-relaxed max-w-xl mx-auto reveal" data-delay="1">From a homeowner's deck to a developer's rezoning — every service has its own anchor link for direct access.</p>
    </div>

    <!-- Service cards grid: 3 cols top, 3 cols bottom -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-border reveal" data-delay="1">
      <!-- Residential -->
      <a href="#contact" id="residential-permits" class="bg-white p-8 lg:p-10 group hover:bg-surface transition-colors duration-300 block">
        <div class="flex items-start justify-between mb-6">
          <div class="w-10 h-10 rounded-sm border border-border flex items-center justify-center group-hover:border-text/20 transition-colors">
            <svg class="w-5 h-5 text-muted group-hover:text-text transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
          </div>
          <span class="text-[10px] tracking-[0.2em] uppercase text-muted">01</span>
        </div>
        <h3 class="text-lg font-normal mb-3 group-hover:translate-x-1 transition-transform">Residential Permits</h3>
        <p class="text-sm text-muted leading-relaxed mb-6">Decks, garages, basements, suites, additions, renovations, retroactive permits.</p>
        <span class="text-[11px] tracking-[0.1em] uppercase opacity-0 group-hover:opacity-100 transition-opacity">Get a Quote →</span>
      </a>

      <!-- Commercial -->
      <a href="#contact" id="commercial-permits" class="bg-white p-8 lg:p-10 group hover:bg-surface transition-colors duration-300 block">
        <div class="flex items-start justify-between mb-6">
          <div class="w-10 h-10 rounded-sm border border-border flex items-center justify-center group-hover:border-text/20 transition-colors">
            <svg class="w-5 h-5 text-muted group-hover:text-text transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          </div>
          <span class="text-[10px] tracking-[0.2em] uppercase text-muted">02</span>
        </div>
        <h3 class="text-lg font-normal mb-3 group-hover:translate-x-1 transition-transform">Commercial Permits</h3>
        <p class="text-sm text-muted leading-relaxed mb-6">Development, building, change of use, tenant improvements, signage, occupancy.</p>
        <span class="text-[11px] tracking-[0.1em] uppercase opacity-0 group-hover:opacity-100 transition-opacity">Get a Quote →</span>
      </a>

      <!-- Land Development -->
      <a href="#contact" id="land-development" class="bg-white p-8 lg:p-10 group hover:bg-surface transition-colors duration-300 block">
        <div class="flex items-start justify-between mb-6">
          <div class="w-10 h-10 rounded-sm border border-border flex items-center justify-center group-hover:border-text/20 transition-colors">
            <svg class="w-5 h-5 text-muted group-hover:text-text transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
          </div>
          <span class="text-[10px] tracking-[0.2em] uppercase text-muted">03</span>
        </div>
        <h3 class="text-lg font-normal mb-3 group-hover:translate-x-1 transition-transform">Land Development</h3>
        <p class="text-sm text-muted leading-relaxed mb-6">Rezoning, subdivision, ASP/NSP amendments, road closures, servicing agreements.</p>
        <span class="text-[11px] tracking-[0.1em] uppercase opacity-0 group-hover:opacity-100 transition-opacity">Get a Quote →</span>
      </a>

      <!-- Appeals -->
      <a href="#contact" id="appeals" class="bg-white p-8 lg:p-10 group hover:bg-surface transition-colors duration-300 block">
        <div class="flex items-start justify-between mb-6">
          <div class="w-10 h-10 rounded-sm border border-border flex items-center justify-center group-hover:border-text/20 transition-colors">
            <svg class="w-5 h-5 text-muted group-hover:text-text transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/></svg>
          </div>
          <span class="text-[10px] tracking-[0.2em] uppercase text-muted">04</span>
        </div>
        <h3 class="text-lg font-normal mb-3 group-hover:translate-x-1 transition-transform">Appeals &amp; Disputes</h3>
        <p class="text-sm text-muted leading-relaxed mb-6">SDAB appeals, LPRT, stop orders, enforcement defence, public hearing representation.</p>
        <span class="text-[11px] tracking-[0.1em] uppercase opacity-0 group-hover:opacity-100 transition-opacity">Get a Quote →</span>
      </a>

      <!-- Fire & Life Safety -->
      <a href="#contact" id="fire-life-safety" class="bg-white p-8 lg:p-10 group hover:bg-surface transition-colors duration-300 block">
        <div class="flex items-start justify-between mb-6">
          <div class="w-10 h-10 rounded-sm border border-border flex items-center justify-center group-hover:border-text/20 transition-colors">

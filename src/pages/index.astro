---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import ImpactBar from '../components/ImpactBar.astro';
import About from '../components/About.astro';
import Services from '../components/Services.astro';
import Projects from '../components/Projects.astro';
import Testimonials from '../components/Testimonials.astro';
import Process from '../components/Process.astro';
import Areas from '../components/Areas.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="TCS Edmonton | General Contractor — Commercial, Industrial & Residential Construction"
  description="TCS Edmonton — Alberta's trusted general contractor specializing in commercial construction, industrial builds, project management and full-scale renovations. 15+ years serving Edmonton and surrounding areas."
>
  <Navbar />
  <main>
    <Hero />
    <ImpactBar />
    <About />
    <Services />
    <Projects />
    <Testimonials />
    <Process />
    <Areas />
    <Contact />
  </main>
  <Footer />
</Layout>
